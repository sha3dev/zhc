{
  "name": "@zhc/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --ignore ../web/node_modules/.vite-temp --ignore ../web/dist src/entrypoints/http/server.ts",
    "build": "tsup",
    "start": "NODE_ENV=production node dist/entrypoints/http/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "1.19.12",
    "dotenv": "^16.4.7",
    "hono": "4.12.10",
    "pg": "^8.13.3",
    "resend": "6.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/pg": "^8.12.1",
    "@vitest/coverage-v8": "^3.1.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.4"
  }
}
