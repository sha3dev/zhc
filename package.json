{
  "name": "zhc",
  "private": true,
  "type": "module",
  "workspaces": ["apps/server", "apps/web"],
  "scripts": {
    "dev": "npm run dev -w @zhc/server",
    "build": "npm run build -w @zhc/web && npm run build -w @zhc/server",
    "start": "npm run start -w @zhc/server",
    "seed:agents": "npm exec -w @zhc/server tsx ../../scripts/seed-agents.ts",
    "seed:agents:reset": "npm exec -w @zhc/server tsx ../../scripts/seed-agents.ts -- --reset",
    "lint": "biome check .",
    "typecheck": "npm run typecheck -w @zhc/web && npm run typecheck -w @zhc/server",
    "test": "npm run test -w @zhc/server",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "9.2.1"
  }
}
